FROM node:20-bookworm-slim

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci

COPY prisma ./prisma
RUN npx prisma generate

COPY server.js ./
COPY docker-entrypoint.sh ./

EXPOSE 5000

CMD ["sh", "docker-entrypoint.sh"]
